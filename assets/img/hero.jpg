/*==============================
 HERO
===============================*/

.hero{
    position:relative;
    height:100vh;
    min-height:700px;
    background-image:
        linear-gradient(
            rgba(5,34,62,.70),
            rgba(9,84,55,.55)
        ),
        url("../img/hero.jpg");
    background-size:cover;
    background-position:center;
    background-attachment:fixed;
    display:flex;
    align-items:center;
    justify-content:center;
    color:white;
    overflow:hidden;
}

.hero-overlay{
    position:absolute;
    inset:0;
    background:
        radial-gradient(
            circle at top,
            rgba(255,255,255,.05),
            transparent 70%
        );
}

.hero-content{
    position:relative;
    z-index:5;
    max-width:900px;
    padding:0 20px;
    text-align:center;
}

.hero-badge{
    display:inline-block;
    padding:10px 18px;
    border-radius:30px;
    background:rgba(255,255,255,.15);
    backdrop-filter:blur(12px);
    font-size:14px;
    letter-spacing:1px;
    margin-bottom:25px;
}

.hero h1{
    font-size:64px;
    font-weight:700;
    line-height:1.15;
    margin-bottom:25px;
}

.hero p{
    font-size:22px;
    line-height:1.8;
    margin-bottom:40px;
    color:#E9ECEF;
}

.hero-buttons{
    display:flex;
    justify-content:center;
    gap:20px;
    flex-wrap:wrap;
}

.hero .btn-success{
    background:#3FA34D;
    border:none;
    padding:16px 34px;
    border-radius:50px;
    font-size:18px;
    transition:.3s;
}

.hero .btn-success:hover{
    transform:translateY(-4px);
}

.hero .btn-outline-light{
    padding:16px 34px;
    border-radius:50px;
}

.scroll-down{
    position:absolute;
    bottom:35px;
    width:100%;
    text-align:center;
}

.scroll-down i{
    color:white;
    font-size:32px;
    animation:float 2s infinite;
}

@keyframes float{
    0%{
        transform:translateY(0);
    }

    50%{
        transform:translateY(12px);
    }

    100%{
        transform:translateY(0);
    }
}

@media(max-width:992px){
    .hero h1{
        font-size:46px;
    }

    .hero p{
        font-size:18px;
    }
}

@media(max-width:768px){
    .hero{
        background-attachment:scroll;
    }
}

@media(max-width:576px){
    .hero{
        min-height:620px;
    }

    .hero h1{
        font-size:34px;
    }

    .hero p{
        font-size:17px;
        line-height:1.6;
    }

    .hero .btn-success,
    .hero .btn-outline-light{
        padding:14px 26px;
        font-size:16px;
    }
}